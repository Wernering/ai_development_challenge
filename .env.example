# ── Shared ──────────────────────────────
DB_PATH=./data/watchdog.db
LOG_DIR=./logs

# ── Log Generator ───────────────────────
MAX_TIME_BETWEEN_LOGS=2
LOG_SERVICE_NAMES=api,worker,scheduler,db

# ── Watchdog ────────────────────────────
ANTHROPIC_API_KEY=
WATCHDOG_POLL_INTERVAL_SECONDS=5
ROLLING_WINDOW_SECONDS=30
ERROR_THRESHOLD=5
CRITICAL_THRESHOLD=10
WEBHOOK_URL=http://localhost:8001/webhook/alert

# ── Webhook Receiver ────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8001

# ── Dashboard ───────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8002
ALERT_LOOKBACK_HOURS=24
